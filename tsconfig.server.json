{
  "compilerOptions": {
    "target":      "ES2022",
    "module":      "CommonJS",
    "moduleResolution": "node",
    "outDir":      "dist/server",
    "rootDir":     "server/src",
    "strict":      true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types":       ["node", "better-sqlite3"]
  },
  "include": ["server/src/**/*"]
}
