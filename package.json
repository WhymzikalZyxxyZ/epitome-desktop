{
  "name": "epitome-desktop",
  "version": "1.0.0",
  "description": "Epitome — the author's command center, as a native desktop app",
  "main": "dist/electron/main.js",
  "author": "Whymzikal Zyxxyz",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev":            "concurrently -n server,client,electron -c cyan,magenta,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:server":     "tsx server/src/index.ts",
    "dev:client":     "vite --config client/vite.config.ts",
    "dev:electron":   "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build":          "npm run build:client && npm run build:server && npm run build:electron",
    "build:client":   "vite build --config client/vite.config.ts",
    "build:server":   "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package":        "npm run build && electron-builder",
    "package:win":    "npm run build && electron-builder --win",
    "package:mac":    "npm run build && electron-builder --mac",
    "package:linux":  "npm run build && electron-builder --linux",
    "postinstall":    "electron-builder install-app-deps"
  },
  "dependencies": {
    "@hono/node-server":    "^1.13.7",
    "@hono/zod-validator":  "^0.4.3",
    "better-sqlite3":       "^11.9.1",
    "drizzle-orm":          "^0.38.4",
    "electron-updater":     "^6.3.9",
    "hono":                 "^4.7.5",
    "zod":                  "^3.24.2"
  },
  "devDependencies": {
    "@electron/rebuild":    "^3.7.1",
    "@tailwindcss/vite":    "^4.1.3",
    "@types/better-sqlite3":"^7.6.12",
    "@types/node":          "^22.0.0",
    "@types/react":         "^18.3.18",
    "@types/react-dom":     "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer":         "^10.4.21",
    "concurrently":         "^9.1.2",
    "cross-env":            "^7.0.3",
    "electron":             "^35.2.1",
    "electron-builder":     "^25.1.8",
    "postcss":              "^8.5.3",
    "tailwindcss":          "^3.4.17",
    "tsx":                  "^4.19.3",
    "typescript":           "^5.8.3",
    "vite":                 "^6.3.1",
    "wait-on":              "^8.0.3"
  }
}
