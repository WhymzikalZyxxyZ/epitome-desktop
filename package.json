{
  "name": "epitome-desktop",
  "version": "1.0.0",
  "description": "Epitome — the author's command center, as a native desktop app",
  "main": "dist/electron/main.js",
  "author": "Whymzikal Zyxxyz",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev":                    "concurrently -n server,client,ecompile,electron -c cyan,magenta,green,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron:compile\" \"npm run dev:electron\"",
    "dev:server":             "tsc -p tsconfig.server.json --watch --preserveWatchOutput",
    "dev:client":             "vite --config client/vite.config.ts",
    "dev:electron:compile":   "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron":           "wait-on dist/server/index.js dist/electron/main.js http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build":          "npm run build:client && npm run build:server && npm run build:electron",
    "build:client":   "vite build --config client/vite.config.ts",
    "build:server":   "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package":        "npm run build && electron-builder",
    "package:win":    "npm run build && electron-builder --win",
    "package:mac":    "npm run build && electron-builder --mac",
    "package:linux":  "npm run build && electron-builder --linux",
    "rebuild:node":   "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@hono/node-server":               "^1.13.7",
    "@hono/zod-validator":             "^0.4.3",
    "@tanstack/react-query":           "^5.80.0",
    "@tiptap/extension-character-count": "^2.22.0",
    "@tiptap/extension-placeholder":   "^2.22.0",
    "@tiptap/extension-text-align":    "^2.27.2",
    "@tiptap/extension-underline":     "^2.27.2",
    "@tiptap/react":                   "^2.22.0",
    "@tiptap/starter-kit":             "^2.22.0",
    "better-sqlite3":                  "^11.9.1",
    "drizzle-orm":                     "^0.38.4",
    "electron-updater":                "^6.3.9",
    "hono":                            "^4.7.5",
    "lucide-react":                    "^0.511.0",
    "react":                           "^18.3.0",
    "react-dom":                       "^18.3.0",
    "react-router-dom":                "^6.30.0",
    "zod":                             "^3.24.2"
  },
  "devDependencies": {
    "@electron/rebuild":               "^3.7.1",
    "@tailwindcss/vite":               "^4.1.3",
    "@testing-library/jest-dom":       "^6.9.1",
    "@testing-library/react":          "^16.3.2",
    "@testing-library/user-event":     "^14.6.1",
    "@types/better-sqlite3":           "^7.6.12",
    "@types/node":                     "^22.0.0",
    "@types/react":                    "^18.3.18",
    "@types/react-dom":                "^18.3.5",
    "@vitejs/plugin-react":            "^4.3.4",
    "@vitest/coverage-v8":             "^4.1.10",
    "autoprefixer":                    "^10.4.21",
    "concurrently":                    "^9.1.2",
    "cross-env":                       "^7.0.3",
    "electron":                        "^35.2.1",
    "electron-builder":                "^25.1.8",
    "jsdom":                           "^29.1.1",
    "msw":                             "^2.15.0",
    "postcss":                         "^8.5.3",
    "tailwindcss":                     "^3.4.17",
    "tsx":                             "^4.19.3",
    "typescript":                      "^5.8.3",
    "vite":                            "^6.3.1",
    "vitest":                          "^4.1.10",
    "wait-on":                         "^8.0.3"
  }
}
