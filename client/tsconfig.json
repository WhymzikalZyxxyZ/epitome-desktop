{
    "compilerOptions": {
        "target":                    "ESNext",
        "useDefineForClassFields":   true,
        "lib":                       ["ESNext", "DOM", "DOM.Iterable"],
        "module":                    "ESNext",
        "moduleResolution":          "Bundler",
        "jsx":                       "react-jsx",
        "strict":                    true,
        "noUncheckedIndexedAccess":  true,
        "noEmit":                    true,
        "skipLibCheck":              true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src", "vite.config.ts"]
}
